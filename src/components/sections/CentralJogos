    placarMandante: 2,
    placarVisitante: 1,
  },
  {
    id: 'novorizontino-botafogosp-1105',
    competicao: 'Série B',
    rodada: '8ª Rodada',
    data: 'Seg, 11/05',
    mandante: 'Novorizontino',
    visitante: 'Botafogo-SP',
    escudoMandante: ESCUDO.novorizontino,
